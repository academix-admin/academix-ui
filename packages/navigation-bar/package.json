{
  "name": "@academix/navigation-bar",
  "version": "0.1.0",
  "description": "A configurable React navigation/tab bar with normal, floating and auto-hide-on-scroll modes.",
  "keywords": ["react", "navigation-bar", "tab-bar", "bottom-nav", "autohide", "floating"],
  "license": "MIT",
  "author": "Academix",
  "repository": { "type": "git", "url": "git+https://github.com/academix-admin/academix-ui.git", "directory": "packages/navigation-bar" },
  "homepage": "https://github.com/academix-admin/academix-ui/tree/main/packages/navigation-bar#readme",
  "bugs": { "url": "https://github.com/academix-admin/academix-ui/issues" },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": { "react": ">=18.0.0", "react-dom": ">=18.0.0" },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  },
  "publishConfig": { "access": "public" }
}
